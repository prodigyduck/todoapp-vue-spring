{
  "name": "todoapp-frontend",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint src --ext .js,.vue --fix",
    "lint:fix": "eslint src --ext .js,.vue --fix",
    "format": "prettier --write src/**/*.{js,vue,ts}"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "axios": "^1.6.2",
    "inter": "^2.1.0",
    "pinia": "^2.1.7",
    "vue": "^3.3.4",
    "vue-router": "^4.2.5",
    "vuetify": "^4.0.0-alpha.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.4.0",
    "vite": "^5.0.0"
  }
}
